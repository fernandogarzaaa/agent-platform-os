# Agent Platform OS consolidated environment manifest.
# Copy this file to .env for local development and replace values for your environment.

# ---------------------------------------------------------------------------
# BACKBONES
# ---------------------------------------------------------------------------
POSTGRES_PRIME_URL=postgresql://agent_platform:agent_platform@postgres_db:5432/agent_platform_os
REDIS_STREAM_URL=redis://redis_broker:6379/0

# ---------------------------------------------------------------------------
# GATEWAY (async_mcp_gateway)
# ---------------------------------------------------------------------------
GATEWAY_PORT=8080
MAX_TOKENS_PER_MIN=120000
COMPLIANCE_MODE=standard

# ---------------------------------------------------------------------------
# DURABLE ENGINE (hydra_engine)
# ---------------------------------------------------------------------------
HYDRA_PORT=8081
HYDRA_STATE_SCHEMA=hydra_state
EVENT_REPLAY_RETRY_LIMIT=5
HYDRA_USE_GATEWAY_MODEL=false
HYDRA_GATEWAY_URL=http://async_mcp_gateway:8080/v1/chat/completions
HYDRA_GATEWAY_TENANT_ID=tenant-alpha
HYDRA_GATEWAY_BEARER_TOKEN=alpha-secret-token
HYDRA_GATEWAY_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# MODEL MESH (synapse_mesh)
# ---------------------------------------------------------------------------
SYNAPSE_PORT=8082
OPENAI_API_URL=https://api.openai.com/v1
ANTHROPIC_API_URL=https://api.anthropic.com
CRITERIA_FALLBACK_MODE=cost_weighted
OPENAI__API_KEY=
OPENAI__BASE_URL=https://api.openai.com
OPENAI__CHAT_PATH=/v1/chat/completions
OPENAI__STREAM_PATH=/v1/chat/completions
OPENAI__DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC__API_KEY=
ANTHROPIC__BASE_URL=https://api.anthropic.com
ANTHROPIC__CHAT_PATH=/v1/messages
ANTHROPIC__STREAM_PATH=/v1/messages
ANTHROPIC__DEFAULT_MODEL=claude-3-5-haiku-latest
LOCAL__API_KEY=
LOCAL__BASE_URL=http://host.docker.internal:3000
LOCAL__CHAT_PATH=/v1/chat/completions
LOCAL__STREAM_PATH=/v1/chat/completions
LOCAL__DEFAULT_MODEL=local-fallback

# ---------------------------------------------------------------------------
# MESSAGING BUS (swarm_bus)
# ---------------------------------------------------------------------------
SWARMBUS_PORT=8085
SWARMBUS_LOOP_DEPTH_LIMIT=32
LOCK_LEASE_TTL_MS=30000

# ---------------------------------------------------------------------------
# VISION INGESTION (spatial_flux)
# ---------------------------------------------------------------------------
SPATIAL_FLUX_PORT=8084
EDGE_DRIFT_THRESHOLD=0.15
IMCODEC_QUALITY_RATIO=80
CLOUD_VLA_ENDPOINT_URL=http://synapse_mesh:8082/v1/vla/commands

# ---------------------------------------------------------------------------
# ROOT HEALTH CHECKER
# ---------------------------------------------------------------------------
HEALTH_TIMEOUT_SECONDS=2.5
